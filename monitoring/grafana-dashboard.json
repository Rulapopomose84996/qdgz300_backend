{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "title": "Row 1 - 流量概览",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Packets Received Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "expr": "sum(rate(receiver_packets_received_total[1m]))",
          "legendFormat": "pps",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Bytes Received Rate (MB/s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "expr": "sum(rate(receiver_bytes_received_total[1m])) / 1024 / 1024",
          "legendFormat": "MB/s",
          "refId": "A"
        }
      ]
    },

    {
      "type": "row",
      "title": "Row 2 - 丢包分析",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "barchart",
      "title": "Dropped Packets by Reason",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "expr": "sum by (reason) (rate(receiver_packets_dropped_total[5m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "stacking": "normal"
      }
    },

    {
      "type": "row",
      "title": "Row 3 - 延迟",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Data Delay Histogram Quantiles",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(receiver_data_delay_seconds_histogram_bucket[5m])))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(receiver_data_delay_seconds_histogram_bucket[5m])))",
          "legendFormat": "P99",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.999, sum by (le) (rate(receiver_data_delay_seconds_histogram_bucket[5m])))",
          "legendFormat": "P99.9",
          "refId": "C"
        }
      ]
    },

    {
      "type": "row",
      "title": "Row 4 - 管道状态",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Active Reorder Contexts",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "expr": "receiver_reasm_contexts_active",
          "legendFormat": "active",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Missing Fragments Total",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "expr": "receiver_missing_fragments_total",
          "legendFormat": "missing",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Buffer Usage",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "expr": "receiver_buffer_usage_current",
          "legendFormat": "current",
          "refId": "A"
        },
        {
          "expr": "receiver_buffer_usage_max",
          "legendFormat": "max",
          "refId": "B"
        }
      ]
    },

    {
      "type": "row",
      "title": "Row 5 - 协议统计",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Control Processed",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 37 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "expr": "rate(receiver_control_packets_processed_total[5m])",
          "legendFormat": "control/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Heartbeat Sent",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 37 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "expr": "rate(receiver_heartbeat_sent_total[5m])",
          "legendFormat": "heartbeat/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "RMA Progress",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 37 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "expr": "receiver_rma_progress_percent",
          "legendFormat": "progress",
          "refId": "A"
        }
      ]
    },

    {
      "type": "row",
      "title": "Row 6 - 系统资源",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 45 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Memory RSS (Bytes)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 46 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "expr": "receiver_memory_rss_bytes",
          "legendFormat": "rss",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Uptime (Seconds)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 46 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "expr": "receiver_uptime_seconds",
          "legendFormat": "uptime",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["receiver", "prometheus"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "current": {
          "selected": true,
          "text": "Prometheus",
          "value": "Prometheus"
        }
      }
    ]
  },
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "title": "Tower Receiver Monitoring",
  "uid": "tower-receiver-monitoring",
  "version": 1,
  "weekStart": ""
}
